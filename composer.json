{
    "name": "miolog/mio-server",
    "description": "Self-hostable backend for MioLog.",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6.7",
        "move-elevator/makefile-tools": "^1.3",
        "nelmio/cors-bundle": "^2.6.1",
        "phpdocumentor/reflection-docblock": "^6.0.3",
        "phpstan/phpdoc-parser": "^2.3.2",
        "symfony/ai-agent": "^0.8.0",
        "symfony/ai-bundle": "^0.8.0",
        "symfony/ai-gemini-platform": "^0.8.1",
        "symfony/ai-lm-studio-platform": "^0.8.0",
        "symfony/asset": "8.0.*",
        "symfony/asset-mapper": "8.0.*",
        "symfony/console": "8.0.*",
        "symfony/doctrine-messenger": "8.0.*",
        "symfony/dotenv": "8.0.*",
        "symfony/expression-language": "8.0.*",
        "symfony/flex": "^2.10",
        "symfony/form": "8.0.*",
        "symfony/framework-bundle": "8.0.*",
        "symfony/http-client": "8.0.*",
        "symfony/intl": "8.0.*",
        "symfony/lock": "8.0.*",
        "symfony/mime": "8.0.*",
        "symfony/monolog-bundle": "^3.0|^4.0.2",
        "symfony/process": "8.0.*",
        "symfony/property-access": "8.0.*",
        "symfony/property-info": "8.0.*",
        "symfony/runtime": "8.0.*",
        "symfony/security-bundle": "8.0.*",
        "symfony/serializer": "8.0.*",
        "symfony/stimulus-bundle": "^3.0",
        "symfony/string": "8.0.*",
        "symfony/translation": "8.0.*",
        "symfony/twig-bundle": "8.0.*",
        "symfony/ux-turbo": "^3.0",
        "symfony/validator": "8.0.*",
        "symfony/web-link": "8.0.*",
        "symfony/yaml": "8.0.*",
        "twig/extra-bundle": "^2.12|^3.24",
        "twig/twig": "^2.12|^3.27"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "cs": "phpcs src",
        "cs:fix": "phpcbf src",
        "phpstan": "phpstan analyse --memory-limit=1G",
        "qa": [
            "@cs",
            "@phpstan"
        ]
    },
    "scripts-descriptions": {
        "cs": "Check coding standard (PSR-12) with PHP_CodeSniffer",
        "cs:fix": "Auto-fix coding standard violations with phpcbf",
        "phpstan": "Run PHPStan static analysis (level 5, src/)",
        "qa": "Run all quality gates: coding standard + static analysis"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-doctrine": "^2.0.22",
        "phpstan/phpstan-symfony": "^2.0.18",
        "phpunit/phpunit": "^13.1.13",
        "squizlabs/php_codesniffer": "^4.0.1",
        "symfony/browser-kit": "8.0.*",
        "symfony/css-selector": "8.0.*",
        "symfony/debug-bundle": "8.0.*",
        "symfony/maker-bundle": "^1.67",
        "symfony/stopwatch": "8.0.*",
        "symfony/web-profiler-bundle": "8.0.*"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://gitlab.com/move-elevator-gmbh/public/makefile-tools.git"
        }
    ]
}

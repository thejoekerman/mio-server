<?xml version="1.0"?>
<ruleset name="MioServer">
    <description>PSR-12 coding standard for MioLog MioServer.</description>

    <file>src</file>
    <file>tests</file>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="parallel" value="8"/>
    <arg value="p"/>

    <!-- Errors block the gate; warnings (e.g. the PSR-12 soft 120-char line limit) stay
         visible but advisory, so CI isn't held hostage by a 121-character test line. -->
    <config name="ignore_warnings_on_exit" value="1"/>

    <rule ref="PSR12"/>
</ruleset>

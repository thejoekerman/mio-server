APP_ENV=dev
APP_SECRET=change-me
APP_SHARE_DIR=var/share
DEFAULT_URI=http://localhost:8000

DATABASE_URL="mysql://${BACKEND_DB_USER:-mio}:${BACKEND_DB_PASSWORD:-db}@db:3306/${BACKEND_DB_NAME:-mio_server}?serverVersion=8.0.32&charset=utf8mb4"
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

BACKEND_HTTP_PORT=8000
BACKEND_DB_PORT=3307
BACKEND_DB_NAME=mio_server
BACKEND_DB_USER=mio
BACKEND_DB_PASSWORD=db
BACKEND_DB_ROOT_PASSWORD=db

LMSTUDIO_HOST_URL=http://host.docker.internal:1234
AI_PROVIDER=
OPENAI_API_KEY=
GEMINI_API_KEY=

IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
